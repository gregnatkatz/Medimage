# Azure AI Configuration
USE_MOCK_DATA=true

# Azure OpenAI Configuration (only needed if USE_MOCK_DATA=false)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_GPT5_DEPLOYMENT=gpt-5-deployment

# Azure ML Configuration (only needed if USE_MOCK_DATA=false)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_ML_WORKSPACE=your-ml-workspace
AZURE_ML_MEDIMAGEINSIGHT_ENDPOINT=medimageinsight-endpoint
AZURE_ML_BIOMEDPARSE_ENDPOINT=biomedparse-endpoint

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,https://your-frontend-url.com
